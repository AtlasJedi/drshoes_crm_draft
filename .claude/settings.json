{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-tooling.sh",
            "timeout": 5,
            "statusMessage": "tooling-lock check"
          }
        ]
      }
    ]
  }
}
