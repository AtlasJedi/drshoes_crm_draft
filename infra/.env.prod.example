# =============================================================================
# Dr Shoes — szablon zmiennych produkcyjnych
# Skopiuj do `.env.prod` w katalogu /opt/drshoes/ i wypełnij sekcje [ZMIEŃ].
# Plik powinien mieć uprawnienia 600 (czytelny tylko dla użytkownika deploy).
# =============================================================================

# --- Hostname publiczny -----------------------------------------------------
# Tymczasowo: drshoes.forcepush.club
# Po migracji na docelową domenę: zmień na crm.drshoes.pl + odkomentuj blok
# w infra/Caddyfile.prod, potem uruchom ./infra/scripts/deploy.sh
APP_HOST=drshoes.forcepush.club

# --- Baza danych ------------------------------------------------------------
POSTGRES_USER=drshoes
POSTGRES_PASSWORD=                            # [ZMIEŃ] losowe min. 24 znaki, bez spacji
POSTGRES_DB=drshoes

# --- Object storage — Cloudflare R2 -----------------------------------------
# Bucket dla zdjęć zleceń (foto buty itp.). Wygeneruj klucze API w Cloudflare:
#   Dashboard → R2 → "Manage R2 API Tokens" → Create API Token
#   Permissions: Object Read & Write na bucketach drshoes-prod + drshoes-prod-backups
#
# R2_ENDPOINT format: https://<account-id>.r2.cloudflarestorage.com
# (account-id znajdziesz w prawym sidebarze dashboardu Cloudflare)
R2_ENDPOINT=                                  # [ZMIEŃ]
R2_BUCKET=drshoes-prod                        # bucket na zdjęcia
R2_ACCESS_KEY=                                # [ZMIEŃ]
R2_SECRET_KEY=                                # [ZMIEŃ]

# --- SMTP (Gmail Miszy) -----------------------------------------------------
# App Password (16 znaków) wygenerowane na https://myaccount.google.com/apppasswords
# UWAGA: to NIE jest zwykłe hasło do konta Gmail.
# Musisz mieć włączoną weryfikację dwuetapową na koncie Misza, żeby tworzyć App Passwords.
SMTP_USERNAME=                                # [ZMIEŃ] np. misza.workshop@gmail.com
SMTP_PASSWORD=                                # [ZMIEŃ] xxxx xxxx xxxx xxxx
SMTP_FROM=                                    # [ZMIEŃ] zwykle = SMTP_USERNAME
SMTP_FROM_NAME=Dr Shoes

# --- Tożsamość warsztatu (wstawiana do treści maili) ------------------------
WORKSHOP_NAME=Dr Shoes
WORKSHOP_ADDRESS=                             # [ZMIEŃ] adres warsztatu Miszy
WORKSHOP_OPENING_HOURS=                       # [ZMIEŃ] np. "pon–pt 10:00–18:00 · sob 11:00–15:00"
WORKSHOP_URL=https://drshoes.pl
