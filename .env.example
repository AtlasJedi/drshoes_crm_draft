# =============================================================================
# Dr Shoes — szablon zmiennych środowiskowych
# Skopiuj ten plik do `.env` i wypełnij sekcje oznaczone [ZMIEŃ].
# Pełna instrukcja: HANDOFF.md
# =============================================================================

# --- Baza danych ------------------------------------------------------------
POSTGRES_USER=drshoes
POSTGRES_PASSWORD=drshoes-dev-secret      # [ZMIEŃ] losowe min. 24 znaki przed produkcją
POSTGRES_DB=drshoes
POSTGRES_PORT=5432

# --- Object storage (zdjęcia zleceń, lokalny MinIO) -------------------------
MINIO_ROOT_USER=drshoes
MINIO_ROOT_PASSWORD=drshoes-dev-secret    # [ZMIEŃ] losowe min. 24 znaki przed produkcją
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=drshoes-prod

# --- Backend + Web ----------------------------------------------------------
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=local              # zostaw "local"
WEB_PORT=3000
NEXT_PUBLIC_API_BASE=/api

# --- Tracing (opcjonalne; można pominąć) ------------------------------------
JAEGER_OTLP_HTTP_PORT=4318
JAEGER_UI_PORT=16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Seed danych testowych (klienci/zlecenia/wiadomości) --------------------
# Zostaw "false" przy normalnym wdrożeniu. "true" wsadza demo dane do bazy.
DRSHOES_DEMO_SEED_ENABLED=false

# --- Wysyłka maili ----------------------------------------------------------
# "logging" — maile tylko w logach (start bez konfiguracji SMTP, dobre na pierwszy boot)
# "smtp"    — realna wysyłka; wypełnij wszystkie SPRING_MAIL_* poniżej
MESSAGING_EMAIL_PROVIDER=logging
MESSAGING_EMAIL_SMTP_FROM=noreply@drshoes.local        # [ZMIEŃ] adres nadawcy
MESSAGING_EMAIL_SMTP_FROM_NAME=Dr Shoes
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=                                  # [ZMIEŃ jeśli provider=smtp]
SPRING_MAIL_PASSWORD=                                  # [ZMIEŃ jeśli provider=smtp] App Password (16 znaków)

# --- Tożsamość warsztatu (wstawiana do treści maili) ------------------------
DRSHOES_WORKSHOP_NAME=Dr Shoes
DRSHOES_WORKSHOP_ADDRESS=Aleje Karola Marcinkowskiego 26, 61-745 Poznań
DRSHOES_WORKSHOP_OPENING_HOURS=pon–pt 10:00–18:00 · sob 11:00–15:00
DRSHOES_WORKSHOP_URL=https://drshoes.pl
